# PostgreSQL connection (used by Docker and Prisma)
POSTGRES_USER=edu_portal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=edu_portal_db
POSTGRES_PORT=5432

# Prisma DATABASE_URL — matches the values above
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# JWT authentication
JWT_SECRET=replace-with-64-char-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Mail — Gmail SMTP (works for both dev and production, no custom domain needed)
# MAIL_USER: your full Gmail address, e.g. yourname@gmail.com
# MAIL_PASS: Google App Password (NOT your Gmail password)
#   Generate one at: https://myaccount.google.com/apppasswords
#   Requires 2-Step Verification to be enabled on your Google account
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-address@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM="EduPortal <your-address@gmail.com>"

# pgAdmin web UI (http://localhost:5050)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050

# Docker service ports (host-side)
API_PORT=3000
WEB_PORT=3001

# CORS — origin allowed by the API (browser-facing URL of the web app)
CORS_ORIGIN=http://localhost:3001

# Next.js public API URL — baked at build time, must be reachable from the browser
NEXT_PUBLIC_API_URL=http://localhost:3000

# Enable demo login button on the login page (baked at build time). Set to "true" on the deployed demo only.
NEXT_PUBLIC_DEMO_ENABLED=false

# Enable POST /auth/demo endpoint on the API. Must match NEXT_PUBLIC_DEMO_ENABLED on the deployed instance.
DEMO_ENABLED=false

# AWS / Production (not needed for local dev)
# ECR_API_URL=<account-id>.dkr.ecr.<region>.amazonaws.com/edu-portal-api
# ECR_WEB_URL=<account-id>.dkr.ecr.<region>.amazonaws.com/edu-portal-web
