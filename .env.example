# PostgreSQL connection (used by Docker and Prisma)
POSTGRES_USER=edu_portal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=edu_portal_db
POSTGRES_PORT=5432

# Prisma DATABASE_URL — matches the values above
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# JWT authentication
JWT_SECRET=replace-with-64-char-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# pgAdmin web UI (http://localhost:5050)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050
